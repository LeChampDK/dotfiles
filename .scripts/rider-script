#!/usr/bin/env bash

# ANSI color codes
GREEN="\033[0;32m"
YELLOW="\033[1;33m"
RESET="\033[0m"
CHECK_MARK="\xE2\x9C\x85"
WARNING="\xE2\x9A\xA0"
ROCKET="\xF0\x9F\x9A\x80"

# Cross-platform Rider launcher
open_rider() {
    case "$(uname -s)" in
        Darwin*) open -a "Rider" "$@" >/dev/null 2>&1 &;;
        *) nohup rider "$@" >/dev/null 2>&1 &;;
    esac
}

# Verify Rider is available
if [[ "$(uname -s)" != Darwin* ]] && ! command -v rider &>/dev/null; then
    echo -e "${WARNING} Error: Rider not found in PATH ${WARNING}"
    exit 1
fi

select_sln_files() {
    echo "Enter the file number you want to open."
    echo "Enter 0 to exit without opening any files."
    read -p "Your choice: " choice
}

git_root=$(git -C "$(pwd)" rev-parse --show-toplevel 2>/dev/null)

if [ -n "$git_root" ]; then
    sln_files=($(find "$git_root" -type f -name "*.sln"))
    num_sln_files=${#sln_files[@]}

        if [ $num_sln_files -eq 0 ]; then
            open_rider .
            echo -e "${GREEN}${ROCKET} Rider started in the background.${RESET}"
        elif [ $num_sln_files -eq 1 ]; then
            open_rider "${sln_files[0]}"
            echo -e "${GREEN}${ROCKET} Rider started for: ${sln_files[0]#$git_root/}${RESET}"
        else
            echo -e "${GREEN}${CHECK_MARK} Found the following .sln files in the repository:${RESET}"
            for ((i=0; i<$num_sln_files; i++)); do
                echo -e "${GREEN}$((i + 1)): ${sln_files[$i]#$git_root/}${RESET}"
            done

            select_sln_files

            if [ "$choice" -eq 0 ]; then
                echo "Exiting without opening any files."
                exit 0
            elif [ "$choice" -gt 0 ] && [ "$choice" -le $num_sln_files ]; then
                selected_sln="${sln_files[$((choice - 1))]}"
                open_rider "$selected_sln"
                echo -e "${GREEN}${ROCKET} Rider started for: ${selected_sln#$git_root/}${RESET}"
            else
                echo -e "${YELLOW}${WARNING} Invalid choice. Select a valid number or 0 to exit.${RESET}"
            fi
        fi
    else
        open_rider
        echo -e "${GREEN}${ROCKET} Rider started in the background.${RESET}"
fi
